# ============================================
# Crypto Funding Rate Arbitrage Engine
# Copy this file to .env and fill in your values
# ============================================

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Exchange API Keys ---
# Binance Futures
BINANCE_API_KEY=your_key_here
BINANCE_API_SECRET=your_secret_here

# Hyperliquid
HYPERLIQUID_API_KEY=your_key_here
HYPERLIQUID_API_SECRET=your_secret_here
HYPERLIQUID_WALLET_ADDRESS=0x...

# Extended (Starknet)
EXTENDED_API_KEY=your_key_here
EXTENDED_API_SECRET=your_secret_here
EXTENDED_WALLET_ADDRESS=0x...
EXTENDED_PRIVATE_KEY=0x...

# Paradex
PARADEX_API_KEY=your_key_here
PARADEX_API_SECRET=your_secret_here
PARADEX_WALLET_ADDRESS=0x...

# --- Strategy Defaults ---
ZSCORE_ENTRY_THRESHOLD=2.0
ZSCORE_EXIT_THRESHOLD=0.5
ZSCORE_LOOKBACK_HOURS=168
MAX_LEVERAGE=3.0
MAX_POSITION_SIZE_USD=10000
DELTA_NEUTRAL_TOLERANCE=0.02
REBALANCE_MARGIN_THRESHOLD=0.15

# --- Bot ---
BOT_MODE=manual
# Options: manual, paper, live
BOT_CHECK_INTERVAL_SECONDS=60
